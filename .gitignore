# Vale downloads style packs into styles/Microsoft on `vale sync`.
# The custom Windsor styles in styles/Windsor are tracked; Microsoft
# is reproducible from .vale.ini, so don't commit it.
styles/Microsoft/

# lychee link-check cache
.lycheecache

# Runtime artifacts from running `windsor` at the repo root (see the
# docs-validation skill). Docs live under content/; the paths below
# only ever contain windsor state. Anchored to the repo root with a
# leading slash so they never shadow real docs (e.g. content/contexts/).
/.scratch/
/.windsor/
/windsor.yaml
/contexts/

# Local toolchain
node_modules/

# macOS / IDE noise
.DS_Store
.idea/
.vscode/
*.swp
